// Parent Class
class Animal {
    void sound() {
        System.out.println("Animal makes a sound");
    }
}
//child class
class Dog extends Animal {
    void bark() {
        System.out.println("Dog barks");
    }
}

//main class
public class InheritanceExample {
    public static void main(String[] args) {
        Dog d = new Dog();

        d.sound();
        d.bark();
    }
}
